{
	"name": "algotrade",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"deploy": "npm run cf-typegen && npm run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:remote": "wrangler d1 migrations apply exchange --remote"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.4.1",
		"@tailwindcss/vite": "^4.3.1",
		"@twa-dev/sdk": "^8.0.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.6.4",
		"lucide-react": "^0.450.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"tailwindcss": "^4.3.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.42.3",
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.12.3",
		"@faker-js/faker": "^10.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.6.0",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.12",
		"wrangler": "^4.105.0"
	}
}
